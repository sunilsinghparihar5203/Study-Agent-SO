# Firebase Configuration
# IMPORTANT: Never commit your actual .env file to version control
# These values should be kept secret and not shared
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Security Notes:
# 1. Use a separate Firebase project for development and production
# 2. Restrict API keys in Google Cloud Console
# 3. Enable Firebase Security Rules
# 4. Monitor Firebase usage for unusual activity
# 5. Regularly rotate secrets and API keys
